# Operapps shared editor conventions — keeps naming/style uniform across all apps.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,mjs,cjs,json}]
indent_style = space
indent_size = 2

[*.{html,css}]
indent_style = tab

[*.py]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
